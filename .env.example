# ==================================================
# TICKZEN STANDALONE EXPORTER CONFIGURATION
# ==================================================
# Copy this to .env and fill in with your credentials.
# Make sure .env is not committed to version control.

# Database Client Type (either "azure" or "supabase")
DB_TYPE=azure

# Azure PostgreSQL Configuration
AZURE_POSTGRES_HOST=tickzen-stock-data.postgres.database.azure.com
AZURE_POSTGRES_PORT=5432
AZURE_POSTGRES_DB=postgres
AZURE_POSTGRES_USER=Jadaunkg
AZURE_POSTGRES_PASSWORD=your_azure_postgres_password
AZURE_POSTGRES_SSLMODE=require
AZURE_POSTGRES_URL=postgresql://Jadaunkg:your_azure_postgres_password@tickzen-stock-data.postgres.database.azure.com:5432/postgres?sslmode=require

# Supabase Configuration (Alternative or fallback destination)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-service-role-key-or-anon-key

# Financial and Macro API Keys
# Get from respective services (Finnhub and FRED are free/low-tier options)
FINNHUB_API_KEY=your_finnhub_key_here
FRED_API_KEY=your_fred_key_here

# Batch Exporter Specific Configuration
# Used to customize ticker lists or offset/limit for multi-deployment setups

# Method 1: Direct Limit and Offset
TICKER_BATCH_LIMIT=70
TICKER_BATCH_OFFSET=0

# Method 2: Instance Partitioning (for Render multi-service setups)
# If INSTANCE_INDEX is set (e.g. 0 to 4), the script divides the total active database
# tickers alphabetically into TOTAL_INSTANCES chunks, and processes this instance's slice.
# INSTANCE_INDEX=0
# TOTAL_INSTANCES=5

